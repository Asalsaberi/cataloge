  <body class="bg-black text-white 
  overflow-x-hidden">
  <header class="sticky top-0 z-[9999]
bg-zinc-950/90 backdrop-blur-md
border-b border-zinc-800">
      <div
        class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center"
      >
      <h1
  onclick="scrollToTop()"
  class="text-2xl font-bold text-yellow-400 cursor-pointer hover:text-yellow-300 transition"
>
  LUXURY STORE
</h1>
<img src="logo.jpg" alt="logo" width="300">
        <button
          onclick="toggleCart()"
          class="bg-yellow-400 text-black px-4 py-2 rounded-xl"
        >
          🛍 سبد خرید (<span id="cart-count">0</span>)
        </button>
      </div>
    </header>
    

    <section class="text-center py-12">
      <h2 class="text-4xl font-bold mb-4">کالکشن تابستانه</h2>
      <p class="text-gray-400">جدیدترین محصولات پوشاک</p>
    </section>
    
<section class="relative h-[500px] overflow-hidden">
  <img
    src="banner.jpg"


    class="w-full h-full object-cover"
    alt="Jeanwest Collection"
  >

  <div class="absolute inset-0 bg-black/60 flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-white mb-4">
        JEANWEST
      </h1>

      <p class="text-xl text-gray-300">
        Modern Fashion Collection 2026
      </p>
    </div>
  </div>
  </section>
  <section class="max-w-7xl mx-auto px-6 py-12">
  <div class="relative h-[500px] rounded-3xl overflow-hidden">


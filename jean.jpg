<html lang="fa" dir="rtl">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Luxury Fashion Catalog</title>
    <script src="https://cdn.tailwindcss.com"></script>
      <style>
.slide{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  opacity:0;
  transition:opacity .8s ease;
}

.slide.active{
  opacity:1;
}
</style>
  </head>
